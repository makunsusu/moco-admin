# ----------------------------------------------------------------------
# Build output
# ----------------------------------------------------------------------
target/
build/
dist/
out/

# Keep wrapper binaries when present
!.mvn/wrapper/maven-wrapper.jar
!gradle/wrapper/gradle-wrapper.jar

# ----------------------------------------------------------------------
# Frontend
# ----------------------------------------------------------------------
moco-ui/node_modules/
moco-ui/dist/
moco-ui/coverage/
moco-ui/.eslintcache
moco-ui/.stylelintcache
moco-ui/.cache/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------------------
# Runtime files
# ----------------------------------------------------------------------
logs/
runtime/
*.log
*.pid
*.seed
*.out
*.err
hs_err_pid*

# ----------------------------------------------------------------------
# IDE / editor
# ----------------------------------------------------------------------
.idea/
.vscode/
*.iws
*.iml
*.ipr
.classpath
.project
.settings/
.factorypath
.apt_generated
.springBeans
.sts4-cache/

# ----------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ----------------------------------------------------------------------
# Temporary files
# ----------------------------------------------------------------------
*.swp
*.swo
*~
*.tmp
*.temp

# ----------------------------------------------------------------------
# Backup / generated metadata
# ----------------------------------------------------------------------
*.xml.versionsBackup
rebel.xml
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/

# ----------------------------------------------------------------------
# Keep generated templates in repo when they are source files
# ----------------------------------------------------------------------
!*/build/*.java
!*/build/*.html
!*/build/*.xml
