# Backend runtime configuration example for moco-admin

# Database
MOCO_DB_URL=jdbc:mysql://127.0.0.1:3306/moco_admin?useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_general_ci&zeroDateTimeBehavior=convertToNull&useSSL=false&serverTimezone=GMT%2B8
MOCO_DB_USERNAME=root
MOCO_DB_PASSWORD=change-me

# Redis
MOCO_REDIS_HOST=127.0.0.1
MOCO_REDIS_PORT=6379
MOCO_REDIS_DATABASE=0
MOCO_REDIS_PASSWORD=

# Security
MOCO_TOKEN_SECRET=replace-with-a-long-random-secret
MOCO_TOKEN_EXPIRE=30

# Optional consoles
MOCO_SWAGGER_ENABLED=false
MOCO_DRUID_CONSOLE_ENABLED=false
MOCO_DRUID_ALLOW=127.0.0.1
MOCO_DRUID_USERNAME=moco
MOCO_DRUID_PASSWORD=change-me
